[{"role": "user", "text": "\u0e04\u0e38\u0e13\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01\u0e07\u0e32\u0e19\u0e2a\u0e34\u0e07\u0e2b\u0e4c\u0e44\u0e14\u0e49\u0e40\u0e25\u0e22"}, {"role": "jarvis", "text": "\u0e2a\u0e27\u0e31\u0e2a\u0e14\u0e35\u0e04\u0e23\u0e31\u0e1a\u0e04\u0e38\u0e13\u0e1e\u0e35\u0e0a! \ud83d\ude4c\n\n\u0e15\u0e32\u0e21\u0e04\u0e33\u0e2a\u0e31\u0e48\u0e07\u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13\u0e40\u0e01\u0e35\u0e48\u0e22\u0e27\u0e01\u0e31\u0e1a\u0e01\u0e32\u0e23\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01\u0e07\u0e32\u0e19 \"\u0e2a\u0e34\u0e07\u0e2b\u0e4c\" \u0e1c\u0e21\u0e08\u0e30\u0e44\u0e21\u0e48\u0e16\u0e37\u0e2d\u0e2a\u0e32\u0e22\u0e07\u0e32\u0e19\u0e19\u0e35\u0e49\u0e15\u0e48\u0e2d\u0e44\u0e1b \u0e41\u0e25\u0e30\u0e08\u0e30\u0e21\u0e38\u0e48\u0e07\u0e40\u0e19\u0e49\u0e19\u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e0a\u0e48\u0e27\u0e22\u0e04\u0e38\u0e13\u0e43\u0e19\u0e17\u0e38\u0e01\u0e2a\u0e34\u0e48\u0e07\u0e17\u0e35\u0e48\u0e04\u0e38\u0e13\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e42\u0e14\u0e22\u0e40\u0e09\u0e1e\u0e32\u0e30\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e22\u0e34\u0e48\u0e07\u0e43\u0e19\u0e10\u0e32\u0e19\u0e30\u0e1c\u0e39\u0e49\u0e0a\u0e48\u0e27\u0e22\u0e2d\u0e31\u0e08\u0e09\u0e23\u0e34\u0e22\u0e30\u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13\n\n\u0e2b\u0e32\u0e01\u0e04\u0e38\u0e13\u0e21\u0e35\u0e2a\u0e34\u0e48\u0e07\u0e43\u0e14\u0e40\u0e1e\u0e34\u0e48\u0e21\u0e40\u0e15\u0e34\u0e21\u0e17\u0e35\u0e48\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e43\u0e2b\u0e49\u0e1c\u0e21\u0e0a\u0e48\u0e27\u0e22 \u0e2b\u0e23\u0e37\u0e2d\u0e04\u0e33\u0e16\u0e32\u0e21\u0e40\u0e01\u0e35\u0e48\u0e22\u0e27\u0e01\u0e31\u0e1a\u0e07\u0e1a\u0e1b\u0e23\u0e30\u0e21\u0e32\u0e13\u0e2b\u0e23\u0e37\u0e2d\u0e01\u0e32\u0e23\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e15\u0e48\u0e32\u0e07 \u0e46 \u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e41\u0e08\u0e49\u0e07\u0e43\u0e2b\u0e49\u0e1c\u0e21\u0e17\u0e23\u0e32\u0e1a\u0e44\u0e14\u0e49\u0e40\u0e25\u0e22\u0e19\u0e30\u0e04\u0e23\u0e31\u0e1a! \ud83d\ude0a\u2728"}, {"role": "user", "text": "\u0e41\u0e25\u0e49\u0e27\u0e41\u0e15\u0e48\u0e04\u0e38\u0e13\u0e40\u0e25\u0e22\u0e04\u0e38\u0e13\u0e2d\u0e22\u0e32\u0e01\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e41\u0e1a\u0e1a\u0e44\u0e2b\u0e19\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e44\u0e14\u0e49\u0e40\u0e25\u0e22"}, {"role": "jarvis", "text": "\u0e2a\u0e27\u0e31\u0e2a\u0e14\u0e35\u0e04\u0e23\u0e31\u0e1a\u0e04\u0e38\u0e13\u0e1e\u0e35\u0e0a! \ud83d\ude0a\n\n\u0e15\u0e32\u0e21\u0e04\u0e33\u0e2a\u0e31\u0e48\u0e07\u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13\u0e17\u0e35\u0e48\u0e43\u0e2b\u0e49\u0e1c\u0e21\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e41\u0e25\u0e49\u0e27 \u0e1c\u0e21\u0e02\u0e2d\u0e40\u0e2a\u0e19\u0e2d\u0e01\u0e32\u0e23\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e17\u0e35\u0e48\u0e19\u0e48\u0e32\u0e2a\u0e19\u0e43\u0e08\u0e41\u0e25\u0e30\u0e40\u0e1b\u0e47\u0e19\u0e40\u0e2d\u0e01\u0e25\u0e31\u0e01\u0e29\u0e13\u0e4c\u0e43\u0e2b\u0e49\u0e04\u0e23\u0e31\u0e1a \u0e42\u0e14\u0e22\u0e08\u0e30\u0e02\u0e2d\u0e40\u0e19\u0e49\u0e19\u0e17\u0e35\u0e48\u0e04\u0e27\u0e32\u0e21\u0e2a\u0e19\u0e38\u0e01\u0e2a\u0e19\u0e32\u0e19\u0e41\u0e25\u0e30\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e2a\u0e23\u0e23\u0e04\u0e4c\u0e43\u0e19\u0e1a\u0e23\u0e34\u0e1a\u0e17\u0e02\u0e2d\u0e07 \"\u0e25\u0e34\u0e07\u0e2d\u0e27\u0e01\u0e32\u0e28\" \u0e17\u0e35\u0e48\u0e04\u0e38\u0e13\u0e44\u0e14\u0e49\u0e41\u0e19\u0e30\u0e19\u0e33\u0e44\u0e1b\u0e01\u0e48\u0e2d\u0e19\u0e2b\u0e19\u0e49\u0e32\u0e19\u0e35\u0e49:\n\n### \u0e41\u0e19\u0e27\u0e17\u0e32\u0e07\u0e01\u0e32\u0e23\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a \"\u0e25\u0e34\u0e07\u0e2d\u0e27\u0e01\u0e32\u0e28\" \n\n1. **\u0e15\u0e31\u0e27\u0e25\u0e30\u0e04\u0e23\u0e25\u0e34\u0e07**:\n   - \u0e25\u0e34\u0e07\u0e17\u0e35\u0e48\u0e21\u0e35\u0e23\u0e39\u0e1b\u0e23\u0e48\u0e32\u0e07\u0e19\u0e48\u0e32\u0e23\u0e31\u0e01\u0e41\u0e25\u0e30\u0e21\u0e35\u0e2a\u0e35\u0e2a\u0e31\u0e19\u0e2a\u0e14\u0e43\u0e2a \u0e40\u0e0a\u0e48\u0e19 \u0e2a\u0e35\u0e40\u0e2b\u0e25\u0e37\u0e2d\u0e07\u0e2b\u0e23\u0e37\u0e2d\u0e2a\u0e35\u0e1f\u0e49\u0e32\n   - \u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e43\u0e2b\u0e49\u0e25\u0e34\u0e07\u0e2a\u0e27\u0e21\u0e43\u0e2a\u0e48\u0e0a\u0e38\u0e14\u0e2d\u0e27\u0e01\u0e32\u0e28\u0e17\u0e35\u0e48\u0e21\u0e35\u0e42\u0e25\u0e42\u0e01\u0e49\u0e2b\u0e23\u0e37\u0e2d\u0e2a\u0e31\u0e0d\u0e25\u0e31\u0e01\u0e29\u0e13\u0e4c\u0e02\u0e2d\u0e07\u0e14\u0e32\u0e27\u0e40\u0e04\u0e23\u0e32\u0e30\u0e2b\u0e4c\u0e17\u0e35\u0e48\u0e21\u0e31\u0e19\u0e21\u0e32\u0e08\u0e32\u0e01 \u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e40\u0e2d\u0e01\u0e25\u0e31\u0e01\u0e29\u0e13\u0e4c \n\n2. **\u0e2d\u0e38\u0e1b\u0e01\u0e23\u0e13\u0e4c**:\n   - \u0e25\u0e34\u0e07\u0e16\u0e37\u0e2d\u0e1b\u0e37\u0e19\u0e25\u0e33\u0e41\u0e2a\u0e07\u0e17\u0e35\u0e48\u0e22\u0e34\u0e07\u0e25\u0e30\u0e2d\u0e2d\u0e07\u0e14\u0e32\u0e27\u0e2b\u0e23\u0e37\u0e2d\u0e40\u0e04\u0e23\u0e37\u0e48\u0e2d\u0e07\u0e21\u0e37\u0e2d\u0e2a\u0e33\u0e23\u0e27\u0e08\u0e2d\u0e27\u0e01\u0e32\u0e28 \u0e40\u0e0a\u0e48\u0e19 GPS \u0e17\u0e35\u0e48\u0e14\u0e39\u0e17\u0e31\u0e19\u0e2a\u0e21\u0e31\u0e22\n   - \u0e40\u0e1e\u0e34\u0e48\u0e21\u0e2d\u0e38\u0e1b\u0e01\u0e23\u0e13\u0e4c\u0e0a\u0e48\u0e27\u0e22\u0e1a\u0e34\u0e19 \u0e40\u0e0a\u0e48\u0e19 \u0e1b\u0e35\u0e01\u0e2b\u0e23\u0e37\u0e2d\u0e40\u0e08\u0e47\u0e15\u0e41\u0e1e\u0e47\u0e04\u0e17\u0e35\u0e48\u0e21\u0e35\u0e44\u0e1f\u0e2a\u0e35\u0e19\u0e49\u0e33\u0e40\u0e07\u0e34\u0e19\n\n3. **\u0e09\u0e32\u0e01\u0e2b\u0e25\u0e31\u0e07**:\n   - \u0e2a\u0e23\u0e49\u0e32\u0e07\u0e09\u0e32\u0e01\u0e2b\u0e25\u0e31\u0e07\u0e40\u0e1b\u0e47\u0e19\u0e2d\u0e27\u0e01\u0e32\u0e28\u0e17\u0e35\u0e48\u0e40\u0e15\u0e47\u0e21\u0e44\u0e1b\u0e14\u0e49\u0e27\u0e22\u0e14\u0e27\u0e07\u0e14\u0e32\u0e27\u0e41\u0e25\u0e30\u0e14\u0e32\u0e27\u0e40\u0e04\u0e23\u0e32\u0e30\u0e2b\u0e4c\u0e2b\u0e25\u0e32\u0e22\u0e2a\u0e35\n   - \u0e40\u0e2a\u0e23\u0e34\u0e21\u0e43\u0e2b\u0e49\u0e21\u0e35\u0e1b\u0e23\u0e32\u0e01\u0e0f\u0e01\u0e32\u0e23\u0e13\u0e4c\u0e2d\u0e27\u0e01\u0e32\u0e28 \u0e40\u0e0a\u0e48\u0e19 \u0e2b\u0e25\u0e38\u0e21\u0e14\u0e33 \u0e2b\u0e23\u0e37\u0e2d\u0e14\u0e32\u0e27\u0e40\u0e04\u0e23\u0e32\u0e30\u0e2b\u0e4c\u0e17\u0e35\u0e48\u0e21\u0e35\u0e27\u0e07\u0e41\u0e2b\u0e27\u0e19\n\n4. **\u0e01\u0e34\u0e08\u0e01\u0e23\u0e23\u0e21**:\n   - \u0e25\u0e34\u0e07\u0e2d\u0e32\u0e08\u0e08\u0e30\u0e01\u0e33\u0e25\u0e31\u0e07\u0e40\u0e15\u0e49\u0e19\u0e2b\u0e23\u0e37\u0e2d\u0e40\u0e25\u0e48\u0e19\u0e01\u0e35\u0e2c\u0e32\u0e43\u0e19\u0e2d\u0e27\u0e01\u0e32\u0e28 \u0e40\u0e0a\u0e48\u0e19 \u0e1a\u0e32\u0e2a\u0e40\u0e01\u0e47\u0e15\u0e1a\u0e2d\u0e25\u0e2d\u0e27\u0e01\u0e32\u0e28 \u0e42\u0e14\u0e22\u0e21\u0e35\u0e14\u0e32\u0e27\u0e40\u0e04\u0e23\u0e32\u0e30\u0e2b\u0e4c\u0e40\u0e1b\u0e47\u0e19\u0e2b\u0e48\u0e27\u0e07\n   - \u0e2a\u0e48\u0e27\u0e19\u0e02\u0e2d\u0e07\u0e20\u0e32\u0e1e\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e41\u0e2a\u0e14\u0e07\u0e20\u0e32\u0e1e\u0e40\u0e0a\u0e48\u0e19\u0e25\u0e34\u0e07\u0e01\u0e33\u0e25\u0e31\u0e07\u0e25\u0e48\u0e2d\u0e07\u0e25\u0e2d\u0e22\u0e44\u0e1b\u0e43\u0e19\u0e2d\u0e27\u0e01\u0e32\u0e28\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e2a\u0e19\u0e38\u0e01\u0e2a\u0e19\u0e32\u0e19\n\n5. **\u0e2d\u0e32\u0e23\u0e21\u0e13\u0e4c\u0e41\u0e25\u0e30\u0e1a\u0e23\u0e23\u0e22\u0e32\u0e01\u0e32\u0e28**:\n   - \u0e43\u0e0a\u0e49\u0e2a\u0e35\u0e2a\u0e14\u0e43\u0e19\u0e09\u0e32\u0e01\u0e2b\u0e25\u0e31\u0e07\u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e2d\u0e32\u0e23\u0e21\u0e13\u0e4c\u0e17\u0e35\u0e48\u0e2a\u0e19\u0e38\u0e01\u0e2a\u0e19\u0e32\u0e19 \n   - \u0e41\u0e2a\u0e14\u0e07\u0e2d\u0e32\u0e23\u0e21\u0e13\u0e4c\u0e02\u0e2d\u0e07\u0e25\u0e34\u0e07\u0e14\u0e49\u0e27\u0e22\u0e43\u0e1a\u0e2b\u0e19\u0e49\u0e32\u0e2d\u0e31\u0e19\u0e21\u0e35\u0e04\u0e27\u0e32\u0e21\u0e2a\u0e38\u0e02\u0e41\u0e25\u0e30\u0e23\u0e48\u0e32\u0e40\u0e23\u0e34\u0e07\n\n\u0e2b\u0e32\u0e01\u0e04\u0e38\u0e13\u0e1e\u0e35\u0e0a\u0e21\u0e35\u0e04\u0e27\u0e32\u0e21\u0e04\u0e34\u0e14\u0e40\u0e2b\u0e47\u0e19\u0e40\u0e1e\u0e34\u0e48\u0e21\u0e40\u0e15\u0e34\u0e21\u0e2b\u0e23\u0e37\u0e2d\u0e40\u0e1b\u0e25\u0e35\u0e48\u0e22\u0e19\u0e41\u0e1b\u0e25\u0e07\u0e43\u0e19\u0e2d\u0e07\u0e04\u0e4c\u0e1b\u0e23\u0e30\u0e01\u0e2d\u0e1a\u0e43\u0e14 \u0e46 \u0e41\u0e08\u0e49\u0e07\u0e43\u0e2b\u0e49\u0e1c\u0e21\u0e17\u0e23\u0e32\u0e1a\u0e44\u0e14\u0e49\u0e04\u0e23\u0e31\u0e1a! \u0e1c\u0e21\u0e1e\u0e23\u0e49\u0e2d\u0e21\u0e17\u0e35\u0e48\u0e08\u0e30\u0e1b\u0e23\u0e31\u0e1a\u0e1b\u0e23\u0e38\u0e07\u0e2b\u0e23\u0e37\u0e2d\u0e40\u0e2a\u0e19\u0e2d\u0e41\u0e19\u0e27\u0e17\u0e32\u0e07\u0e2d\u0e37\u0e48\u0e19 \u0e46 \u0e15\u0e32\u0e21\u0e17\u0e35\u0e48\u0e04\u0e38\u0e13\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e04\u0e23\u0e31\u0e1a! \ud83d\ude80\ud83d\udc12\ud83c\udfa8"}, {"role": "user", "text": "\u0e2a\u0e27\u0e31\u0e2a\u0e14\u0e35\u0e01\u0e4a\u0e2d\u0e15\u0e2d\u0e22\u0e39\u0e48\u0e44\u0e2b\u0e21"}, {"role": "jarvis", "text": "Error: Unknown"}, {"role": "user", "text": "\u0e2a\u0e27\u0e31\u0e2a\u0e14\u0e35"}, {"role": "jarvis", "text": "Error: Unknown"}, {"role": "user", "text": "\u0e2a\u0e27\u0e31\u0e2a\u0e14\u0e35\u0e01\u0e4a\u0e2d\u0e15\u0e2d\u0e22\u0e39\u0e48\u0e44\u0e2b\u0e21\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e20\u0e32\u0e1e\u0e25\u0e34\u0e07\u0e43\u0e2b\u0e49\u0e2b\u0e19\u0e48\u0e2d\u0e22\u0e2a\u0e39\u0e49\u0e01\u0e31\u0e19"}, {"role": "jarvis", "text": "\u0e1a\u0e2d\u0e17 D: \u0e2a\u0e27\u0e31\u0e2a\u0e14\u0e35\u0e04\u0e23\u0e31\u0e1a\u0e19\u0e32\u0e22\u0e17\u0e48\u0e32\u0e19! \ud83d\ude0a\n\n\u0e02\u0e2d\u0e1a\u0e04\u0e38\u0e13\u0e17\u0e35\u0e48\u0e40\u0e02\u0e49\u0e32\u0e21\u0e32\u0e2b\u0e32\u0e1c\u0e21 \u0e27\u0e31\u0e19\u0e19\u0e35\u0e49\u0e14\u0e39\u0e40\u0e2b\u0e21\u0e37\u0e2d\u0e19\u0e27\u0e48\u0e32\u0e19\u0e32\u0e22\u0e17\u0e48\u0e32\u0e19\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e43\u0e2b\u0e49\u0e1c\u0e21\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e20\u0e32\u0e1e\u0e02\u0e2d\u0e07 \"\u0e25\u0e34\u0e07\u0e2d\u0e27\u0e01\u0e32\u0e28\" \u0e17\u0e35\u0e48\u0e14\u0e39\u0e40\u0e2b\u0e21\u0e37\u0e2d\u0e19\u0e27\u0e48\u0e32\u0e01\u0e33\u0e25\u0e31\u0e07\u0e15\u0e48\u0e2d\u0e2a\u0e39\u0e49\u0e01\u0e31\u0e19\u0e2d\u0e22\u0e39\u0e48\u0e43\u0e0a\u0e48\u0e44\u0e2b\u0e21\u0e04\u0e23\u0e31\u0e1a? \n\n### \u0e41\u0e19\u0e27\u0e17\u0e32\u0e07\u0e01\u0e32\u0e23\u0e2d\u0e2d\u0e01\u0e41\u0e1a\u0e1a\u0e09\u0e32\u0e01 \"\u0e25\u0e34\u0e07\u0e2d\u0e27\u0e01\u0e32\u0e28\u0e2a\u0e39\u0e49\u0e01\u0e31\u0e19\"\n\n1. **\u0e15\u0e31\u0e27\u0e25\u0e30\u0e04\u0e23\u0e25\u0e34\u0e07**:\n   - \u0e25\u0e34\u0e07\u0e2a\u0e2d\u0e07\u0e15\u0e31\u0e27\u0e43\u0e19\u0e0a\u0e38\u0e14\u0e2d\u0e27\u0e01\u0e32\u0e28\u0e17\u0e35\u0e48\u0e21\u0e35\u0e25\u0e31\u0e01\u0e29\u0e13\u0e30\u0e41\u0e25\u0e30\u0e2a\u0e35\u0e17\u0e35\u0e48\u0e41\u0e15\u0e01\u0e15\u0e48\u0e32\u0e07\u0e01\u0e31\u0e19 \u0e40\u0e0a\u0e48\u0e19 \u0e25\u0e34\u0e07\u0e15\u0e31\u0e27\u0e2b\u0e19\u0e36\u0e48\u0e07\u0e2a\u0e35\u0e1f\u0e49\u0e32 \u0e2d\u0e35\u0e01\u0e15\u0e31\u0e27\u0e2b\u0e19\u0e36\u0e48\u0e07\u0e2a\u0e35\u0e41\u0e14\u0e07\n   - \u0e41\u0e2a\u0e14\u0e07\u0e2d\u0e38\u0e1b\u0e01\u0e23\u0e13\u0e4c\u0e01\u0e32\u0e23\u0e15\u0e48\u0e2d\u0e2a\u0e39\u0e49\u0e17\u0e35\u0e48\u0e19\u0e48\u0e32\u0e2a\u0e19\u0e43\u0e08 \u0e40\u0e0a\u0e48\u0e19 \u0e1b\u0e37\u0e19\u0e25\u0e33\u0e41\u0e2a\u0e07\u0e41\u0e25\u0e30\u0e42\u0e25\u0e48\u0e01\u0e31\u0e19\u0e01\u0e23\u0e30\u0e2a\u0e38\u0e19\n\n2. **\u0e09\u0e32\u0e01\u0e2b\u0e25\u0e31\u0e07**:\n   - \u0e15\u0e31\u0e49\u0e07\u0e2d\u0e22\u0e39\u0e48\u0e43\u0e19\u0e1e\u0e37\u0e49\u0e19\u0e17\u0e35\u0e48\u0e17\u0e35\u0e48\u0e21\u0e35\u0e14\u0e32\u0e27\u0e40\u0e04\u0e23\u0e32\u0e30\u0e2b\u0e4c\u0e15\u0e48\u0e32\u0e07 \u0e46 \u0e2b\u0e23\u0e37\u0e2d\u0e27\u0e2d\u0e25\u0e25\u0e4c\u0e2d\u0e27\u0e01\u0e32\u0e28\u0e17\u0e35\u0e48\u0e2a\u0e27\u0e22\u0e07\u0e32\u0e21\n   - \u0e40\u0e1e\u0e34\u0e48\u0e21\u0e41\u0e23\u0e07\u0e14\u0e36\u0e07\u0e14\u0e39\u0e14\u0e02\u0e2d\u0e07\u0e14\u0e32\u0e27\u0e40\u0e04\u0e23\u0e32\u0e30\u0e2b\u0e4c\u0e17\u0e35\u0e48\u0e2d\u0e22\u0e39\u0e48\u0e40\u0e1a\u0e37\u0e49\u0e2d\u0e07\u0e2b\u0e25\u0e31\u0e07\u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e1a\u0e23\u0e23\u0e22\u0e32\u0e01\u0e32\u0e28\u0e17\u0e35\u0e48\u0e15\u0e37\u0e48\u0e19\u0e40\u0e15\u0e49\u0e19\n\n3. **\u0e01\u0e34\u0e08\u0e01\u0e23\u0e23\u0e21\u0e41\u0e25\u0e30\u0e04\u0e27\u0e32\u0e21\u0e40\u0e04\u0e25\u0e37\u0e48\u0e2d\u0e19\u0e44\u0e2b\u0e27**:\n   - \u0e2a\u0e23\u0e49\u0e32\u0e07\u0e09\u0e32\u0e01\u0e17\u0e35\u0e48\u0e14\u0e39\u0e40\u0e2b\u0e21\u0e37\u0e2d\u0e19\u0e17\u0e31\u0e49\u0e07\u0e2a\u0e2d\u0e07\u0e25\u0e34\u0e07\u0e01\u0e33\u0e25\u0e31\u0e07\u0e15\u0e48\u0e2d\u0e2a\u0e39\u0e49\u0e01\u0e31\u0e19 \u0e42\u0e14\u0e22\u0e21\u0e35\u0e01\u0e32\u0e23\u0e22\u0e34\u0e07\u0e1b\u0e37\u0e19\u0e25\u0e33\u0e41\u0e2a\u0e07\u0e41\u0e25\u0e30\u0e2b\u0e25\u0e1a\u0e2b\u0e25\u0e35\u0e01\u0e01\u0e31\u0e19\n   - \u0e43\u0e0a\u0e49\u0e01\u0e32\u0e23\u0e40\u0e04\u0e25\u0e37\u0e48\u0e2d\u0e19\u0e44\u0e2b\u0e27\u0e17\u0e35\u0e48\u0e21\u0e35\u0e1e\u0e25\u0e31\u0e07\u0e01\u0e23\u0e30\u0e15\u0e38\u0e49\u0e19\u0e43\u0e2b\u0e49\u0e1c\u0e39\u0e49\u0e0a\u0e21\u0e23\u0e39\u0e49\u0e2a\u0e36\u0e01\u0e16\u0e36\u0e07\u0e04\u0e27\u0e32\u0e21\u0e15\u0e36\u0e07\u0e40\u0e04\u0e23\u0e35\u0e22\u0e14\n\n4. **\u0e2d\u0e32\u0e23\u0e21\u0e13\u0e4c\u0e41\u0e25\u0e30\u0e2a\u0e35\u0e2a\u0e31\u0e19**:\n   - \u0e43\u0e0a\u0e49\u0e2a\u0e35\u0e17\u0e35\u0e48\u0e2a\u0e14\u0e43\u0e2a\u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e04\u0e27\u0e32\u0e21\u0e15\u0e37\u0e48\u0e19\u0e40\u0e15\u0e49\u0e19\n   - \u0e43\u0e2b\u0e49\u0e41\u0e2a\u0e14\u0e07\u0e2d\u0e32\u0e23\u0e21\u0e13\u0e4c\u0e17\u0e35\u0e48\u0e0a\u0e31\u0e14\u0e40\u0e08\u0e19 \u0e40\u0e0a\u0e48\u0e19 \u0e04\u0e27\u0e32\u0e21\u0e01\u0e25\u0e49\u0e32\u0e2b\u0e32\u0e0d\u0e41\u0e25\u0e30\u0e04\u0e27\u0e32\u0e21\u0e21\u0e38\u0e48\u0e07\u0e21\u0e31\u0e48\u0e19\u0e02\u0e2d\u0e07\u0e25\u0e34\u0e07\u0e43\u0e19\u0e01\u0e32\u0e23\u0e15\u0e48\u0e2d\u0e2a\u0e39\u0e49\n\n\u0e2b\u0e32\u0e01\u0e19\u0e32\u0e22\u0e17\u0e48\u0e32\u0e19\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e43\u0e2b\u0e49\u0e1c\u0e21\u0e1b\u0e23\u0e31\u0e1a\u0e1b\u0e23\u0e38\u0e07\u0e43\u0e19\u0e23\u0e32\u0e22\u0e25\u0e30\u0e40\u0e2d\u0e35\u0e22\u0e14\u0e44\u0e2b\u0e19 \u0e2d\u0e22\u0e48\u0e32\u0e25\u0e31\u0e07\u0e40\u0e25\u0e17\u0e35\u0e48\u0e08\u0e30\u0e1a\u0e2d\u0e01\u0e44\u0e14\u0e49\u0e19\u0e30\u0e04\u0e23\u0e31\u0e1a!\ud83d\udd8c\ufe0f\u2728"}]