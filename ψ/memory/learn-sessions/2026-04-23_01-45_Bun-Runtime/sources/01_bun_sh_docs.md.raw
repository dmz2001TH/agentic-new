tle\":\"Hashing\",\"description\":\"Bun provides a set of utility functions for hashing and verifying passwords with various cryptographically secure algorithms\",\"href\":\"/runtime/hashing\"},{\"title\":\"Glob\",\"description\":\"Use Bun's fast native implementation of file globbing\",\"href\":\"/runtime/glob\"},{\"title\":\"Semver\",\"description\":\"Use Bun's semantic versioning API\",\"href\":\"/runtime/semver\"},{\"title\":\"Color\",\"description\":\"Format colors as CSS, ANSI, numbers, hex strings, and more\",\"href\":\"/runtime/color\"},{\"title\":\"Utils\",\"description\":\"Use Bun's utility functions to work with the runtime\",\"href\":\"/runtime/utils\"}]},{\"group\":\"Standards \u0026 Compatibility\",\"icon\":\"badge-check\",\"pages\":[{\"title\":\"Globals\",\"description\":\"Use Bun's global objects\",\"href\":\"/runtime/globals\"},{\"title\":\"Bun APIs\",\"description\":\"Overview of Bun's native APIs available on the Bun global object and built-in modules\",\"mode\":\"center\",\"href\":\"/runtime/bun-apis\"},{\"title\":\"Web APIs\",\"description\":\"Web-standard APIs supported by Bun for server-side JavaScript\",\"mode\":\"center\",\"href\":\"/runtime/web-apis\"},{\"title\":\"Node.js Compatibility\",\"description\":\"Bun's compatibility status with Node.js APIs, modules, and globals\",\"href\":\"/runtime/nodejs-compat\"}]},{\"group\":\"Contributing\",\"icon\":\"heart\",\"pages\":[{\"title\":\"Roadmap\",\"description\":\"Bun's roadmap and long-term plans\",\"href\":\"/project/roadmap\"},{\"title\":\"Benchmarking\",\"description\":\"How to benchmark Bun\",\"href\":\"/project/benchmarking\"},{\"title\":\"Contributing\",\"description\":\"Contributing to Bun\",\"href\":\"/project/contributing\"},{\"title\":\"Building Windows\",\"description\":\"Building Bun on Windows\",\"href\":\"/project/building-windows\"},{\"title\":\"Bindgen\",\"description\":\"Bindgen for Bun\",\"href\":\"/project/bindgen\"},{\"title\":\"License\",\"description\":\"License for Bun\",