bunjs\"}},\"seo\":{\"metatags\":{\"canonical\":\"https://bun.com/docs\"}},\"fonts\":{\"heading\":{\"family\":\"Inter Display Bold\",\"source\":\"https://mintlify-assets.b-cdn.net/fonts/InterDisplay-Bold.woff2\",\"format\":\"woff2\"}},\"icons\":{\"library\":\"lucide\"},\"styling\":{\"codeblocks\":\"$16:1:props:children:props:codeblockTheme\",\"latex\":true},\"contextual\":{\"options\":[\"copy\",\"view\",\"claude\",\"mcp\",\"vscode\"],\"display\":\"header\"}},\"docsNavWithMetadata\":{\"global\":null,\"tabs\":[{\"tab\":\"Runtime\",\"icon\":\"cog\",\"groups\":[{\"group\":\"Get Started\",\"icon\":\"terminal\",\"pages\":[{\"title\":\"Welcome to Bun\",\"description\":\"Bun is an all-in-one toolkit for developing modern JavaScript/TypeScript applications.\",\"mode\":\"center\",\"href\":\"/index\"},{\"title\":\"Installation\",\"description\":\"Install Bun with npm, Homebrew, Docker, or the official script.\",\"href\":\"/installation\"},{\"title\":\"Quickstart\",\"description\":\"Build your first app with Bun\",\"href\":\"/quickstart\"},{\"title\":\"TypeScript\",\"description\":\"Using TypeScript with Bun, including type definitions and compiler options\",\"href\":\"/typescript\"},{\"title\":\"TypeScript 6 and 7\",\"description\":\"How to configure Bun's type definitions for TypeScript 6.0 and 7.0, which no longer auto-discover @types packages. Fix 'Cannot find name Bun' and other missing type errors after upgrading TypeScript.\",\"href\":\"/typescript-6\"},{\"title\":\"bun init\",\"description\":\"Scaffold an empty Bun project with the interactive `bun init` command\",\"href\":\"/runtime/templating/init\"},{\"title\":\"bun create\",\"description\":\"Create a new Bun project from a React component, a `create-\u003ctemplate\u003e` npm package, a GitHub repo, or a local template\",\"href\":\"/runtime/templating/create\"}]},{\"group\":\"Core Runtime\",\"icon\":\"cog\",\"pages\":[{\"title\":\"Bun Runtime\",\"description\":\"Execute JavaScript/TypeScript files, package.json scripts, and executable packages with Bun's fast runtime.\",\"href\":\"/runtime/index\"},{\"title\":\"Watch Mode\",\"description\":\"Automatic reloading in Bun with --watch and --hot modes\",\"href\":\"/runtime/watch-mode\"},{\"title\":\"Debugging\",\"description\":\"Debug your Bun code with an interactive debugger using WebKit Inspector Protocol\",\"href\":\"/runtime/debugger\"},{\"title\":\"REPL\",\"description\":\"An interactive JavaScript and TypeScript REPL with syntax highlighting, history, and tab completion\",\"href\":\"/runtime/repl\"},{\"title\":\"bunfig.toml\",\"description\":\"Configure Bun's behavior using its configuration file bunfig.toml\",\"href\":\"/runtime/bunfig\"}]},{\"group\":\"File \u0026 Module System\",\"icon\":\"file\",\"pages\":[{\"title\":\"File Types\",\"description\":\"File types and loaders supported by Bun's bundler and runtime\",\"href\":\"/runtime/file-types\"},{\"title\":\"Module Resolution\",\"description\":\"How Bun resolves modules and handles imports in JavaScript and TypeScript\",\"href\":\"/runtime/module-resolution\"},{\"title\":\"JSX\",\"description\":\"Built-in JSX and TSX support in Bun with configurable transpilation options\",\"href\":\"/runtime/jsx\"},{\"title\":\"Auto-install\",\"description\":\"Bun's automatic package installation feature for standalone script execution\",\"href\":\"/runtime/auto-install\"},{\"title\":\"Plugins\",\"description\":\"Universal plugin API for extending Bun's runtime and bundler\",\"href\":\"/runtime/plugins\"},{\"title\":\"File System Router\",\"description\":\"Bun provides a fast API for resolving routes against file-system paths\",\"href\":\"/runtime/file-system-router\"}]},{\"group\":\"HTTP server\",\"icon\":\"server\",\"pages\":[{\"title\":\"Server\",\"description\":\"Use `Bun.serve` to start a high-performance HTTP server in Bun\",\"href\":\"/runtime/http/server\"},{\"title\":\"Routing\",\"description\":\"Define routes in `Bun.serve` using static paths, parameters, and wildcards\",\"href\":\"/runtime/http/routing\"},{\"title\":\"Cookies\",\"description\":\"Work with cookies in HTTP requests and responses using Bun's built-in Cookie API.\",\"href\":\"/runtime/http/cookies\"},{\"title\":\"TLS\",\"description\":\"Enable TLS in Bun.serve\",\"href\":\"/runtime/http/tls\"},{\"title\":\"Error Handling\",\"description\":\"Learn how to handle errors in Bun's development server\",\"href\":\"/runtime/http/error-handling\"},{\"title\":\"Metrics\",\"description\":\"Monitor server activity with built-in metrics\",\"href\":\"/runtime/http/metrics\"}]},{\"group\":\"Networking\",\"icon\":\"globe\",\"expanded\":true,\"pages\":[{\"title\":\"Fetch\",\"description\":\"Send HTTP requests with Bun's fetch API\",\"href\":\"/runtime/networking/fetch\"},{\"title\":\"WebSockets\",\"description\":\"Server-side WebSockets in Bun\",\"href\":\"/runtime/http/websockets\"},{\"title\":\"TCP\",\"description\":\"Use Bun's native TCP API to implement performance sensitive systems like database clients, game servers, or anything that needs to communicate over TCP (instead of HTTP)\",\"href\":\"/runtime/networking/tcp\"},{\"title\":\"UDP\",\"description\":\"Use Bun's UDP API to implement services with advanced real-time requirements, such as voice chat.\",\"href\":\"/runtime/networking/udp\"},{\"title\":\"DNS\",\"description\":\"Use Bun's DNS module to resolve DNS records\",\"href\":\"/runtime/networking/dns\"}]},{\"group\":\"Data \u0026 Storage\",\"icon\":\"database\",\"pages\":[{\"title\":\"Cookies\",\"description\":\"Use Bun's native APIs for working with HTTP cookies\",\"href\":\"/runtime/cookies\"},{\"title\":\"File I/O\",\"description\":\"Bun provides a set of optimized APIs for reading and writing files.\",\"href\":\"/runtime/file-io\"},{\"title\":\"Streams\",\"description\":\"Use Bun's streams API to work with binary data without loading it all into memory at once\",\"href\":\"/runtime/streams\"},{\"title\":\"Binary Data\",\"description\":\"Working with binary data in JavaScript\",\"href\":\"/runtime/binary-data\"},{\"title\":\"Archive\",\"description\":\"Create and extract tar archives with Bun's fast native implementation\",\"href\":\"/runtime/archive\"},{\"title\":\"SQL\",\"description\":\"Bun provides native bindings for working with SQL databases through a unified Promise-based API that supports PostgreSQL, MySQL, and SQLite.\",\"href\":\"/runtime/sql\"},{\"title\":\"SQLite\",\"description\":\"Bun natively implements a high-performance SQLite3 driver.\",\"href\":\"/runtime/sqlite\"},{\"title\":\"S3\",\"description\":\"Bun provides fast, native bindings for interacting with S3-compatible object storage services.\",\"href\":\"/runtime/s3\"},{\"title\":\"Redis\",\"description\":\"Use Bun's native Redis client with a Promise-based API\",\"href\":\"/runtime/redis\"}]},{\"group\":\"Concurrency\",\"icon\":\"split\",\"pages\":[{\"title\":\"Workers\",\"description\":\"Use Bun's Workers API to create and communicate with a new JavaScript instance running on a separate thread while sharing I/O resources with the main thread\",\"href\":\"/runtime/workers\"}]},{\"group\":\"Process \u0026 System\",\"icon\":\"computer\",\"pages\":[{\"title\":\"Environment Variables\",\"description\":\"Read and configure environment variables in Bun, including automatic .env file support\",\"href\":\"/runtime/environment-variables\"},{\"title\":\"Shell\",\"description\":\"Use Bun's shell scripting API to run shell commands from JavaScript\",\"href\":\"/runtime/shell\"},{\"title\":\"Spawn\",\"description\":\"Spawn child processes with `Bun.spawn` or `Bun.spawnSync`\",\"href\":\"/runtime/child-process\"},{\"title\":\"WebView\",\"description\":\"Control a headless browser from Bun for automation, testing, and scraping — zero dependencies on macOS, Chrome DevTools Protocol everywhere else\",\"href\":\"/runtime/webview\"},{\"title\":\"Cron\",\"description\":\"Schedule and parse cron jobs with Bun\",\"href\":\"/runtime/cron\"}]},{\"group\":\"Interop \u0026 Tooling\",\"icon\