# Force LF line endings for shell scripts (prevent CRLF on Windows checkout)
*.sh text eol=lf
*.bash text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf

# Windows-specific files keep CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
